<% layout("/layouts/boilerplate.ejs") -%>
<body>
    <div class="row mt-2">
      <div class="col-8 offset-2">
         <h3>Create a New Listing</h3>
         <br><br>
     <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data"> 
      <div class="mb-3">
         <label for="title" class="form-label">Title</label>
         <input name="listing[title]" placeholder="Add a Catchy Title" type="text" class="form-control" required >
         <div class="valid-feedback">Title Looks good!</div>
    </div>
    <div class="mb-3">
       <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" placeholder="enter the description" type="text" class="form-control" required> 
          </textarea>
          <div class="invalid-feedback">Please enter short description</div>
    </div>
     <!-- CATEGORY FIELD -->
    <div class="mb-3">
        <label class="form-label">Category</label>
        <select
            name="listing[category]"
            class="form-select"
            required
        >
            <option value="">Select Category</option>
            <option value="trending">Trending</option>
            <option value="rooms">Rooms</option>
            <option value="iconic-cities">Iconic Cities</option>
            <option value="mountains">Mountains</option>
            <option value="castles">Castles</option>
            <option value="amazing-pools">Amazing Pools</option>
            <option value="camping">Camping</option>
            <option value="farms">Farms</option>
            <option value="luxury">Luxury</option>
            <option value="arctic">Arctic</option>
            <option value="vineyards">Vineyards</option>
        </select>
    </div>

     <div class="mb-3">
        <label for="image" class="form-label">Image</label>
        <input name="listing[image]" placeholder="enter image URL/link" type="file" class="form-control">
     </div>
     <div class="row">
      <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" placeholder="1200"  class="form-control" required>
        <div class="invalid-feedback">Please enter valid price</div>
    </div>
     <div class="mb-3 col-md-8">
           <label for="country" class="form-label">Country</label>
           <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
           <div class="invalid-feedback">Please enter country name</div>
    </div>
     </div>

    <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input name="listing[location]" placeholder="Jaipur" type="text" class="form-control" required>
        <div class="invalid-feedback">Please enter location</div>
    </div>
   

    <button class="btn btn-dark  add-btn mt-3">Add</button>
    </form>
      </div>
    </div>
    
</body>
</html>