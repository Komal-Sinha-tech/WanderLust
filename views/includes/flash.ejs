<!-- <h4 class="alert alert-success">New Listing Created</h4> -->
<% if(success && success.length > 0) { %>
    <div class="alert alert-success alert-dismissible fade show col-6 offset-3">
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if(error && error.length ) { %>
    <div class="alert alert-danger alert-dismissible fade show col-6 offset-3">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>