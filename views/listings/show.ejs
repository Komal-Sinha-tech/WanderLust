<% layout("/layouts/boilerplate.ejs") -%>
<body>
    
    <div class="row mt-3">
        <div class="col-8 offset-3">
            <h3><%= listing.title %></h3>
            </div>
        <div class="card col-6 offset-3 show-card">
    
  <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
        <br>
    <%= listing.description %> <br>
    <!-- <%=  listing.image.url %> <br> -->
    &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "Price not available" %> <br>
    <%= listing.location %><br>
    <%= listing.country %>


</p>
  </div>
    </div>
    <div class="btns">
     <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark add-btn col-1 offset-3">Edit</a>
    
    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
      <button class="btn btn-dark add-btn  offset-5">Delete</button>
    </form>
      </div>
      <div class="col-8 offset-3 mb-3" >
        <br><hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing.id %>/reviews" method="post">
          <div  class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
        </div>
        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comments</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"></textarea>
        </div>
        <button class="btn btn-outline-dark mt-3">Submit</button>
        </form>
      </div>

      </div>

</body>